{
	"version": 5,
	"cmakeMinimumRequired": {
		"major": 3,
		"minor": 24,
		"patch": 0
	},
	"configurePresets": [
		{
			"name": "default",
			"displayName": "Default Ninja local",
			"generator": "Ninja",
			"binaryDir": "${sourceDir}/build",
			"cacheVariables": {
				"CMAKE_BUILD_TYPE": "Debug",
				"CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
			}
		},
		{
			"name": "relwithdebinfo",
			"displayName": "RelWithDebInfo benchmark",
			"inherits": "default",
			"binaryDir": "${sourceDir}/build-relwithdebinfo",
			"cacheVariables": {
				"CMAKE_BUILD_TYPE": "RelWithDebInfo",
				"CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
				"MST_ENABLE_RENDERING": "OFF"
			}
		}
	],
	"buildPresets": [
		{
			"name": "default",
			"configurePreset": "default"
		},
		{
			"name": "relwithdebinfo",
			"configurePreset": "relwithdebinfo"
		}
	]
}
