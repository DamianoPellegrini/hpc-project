{
	"version": 5,
	"cmakeMinimumRequired": {
		"major": 4,
		"minor": 3,
		"patch": 0
	},
	"configurePresets": [
		{
			"name": "default",
			"displayName": "Default Ninja local",
			"generator": "Ninja",
			"binaryDir": "${sourceDir}/build",
			"cacheVariables": {
				"CMAKE_BUILD_TYPE": "Debug",
				"CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
			}
		}
	],
	"buildPresets": [
		{
			"name": "default",
			"configurePreset": "default"
		}
	]
}
